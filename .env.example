# LandonOS: Performance Research Cockpit — example environment file
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in values as needed:
#     cp .env.example .env
# NEVER commit a real ".env" — it is gitignored. Use placeholders only here.
#
# IMPORTANT: LandonOS is currently a FRONTEND-ONLY app (no backend, no database,
# no external integrations). The app runs and builds with NO env file at all.
# The variables below are the only ones the build actually reads today, plus a
# clearly-marked "future" section for the later Cursor/server phase.

# --- Used by the build/dev/preview today (all optional, sane defaults) --------
# Port the Vite dev/preview server binds to. Defaults to 5000 if unset.
PORT=5000

# Base path the app is served under. Defaults to "/" if unset.
# Set to a sub-path (e.g. "/landonos/") only if hosting under a sub-route.
BASE_PATH=/

# Standard Node environment. "development" or "production".
NODE_ENV=development

# -----------------------------------------------------------------------------
# --- FUTURE ONLY — NOT used by the current frontend-only app ------------------
# Do NOT set these now. They are placeholders for the later Cursor/AWS phase if
# a real backend, database, AI, or auth is added. Leaving them blank/absent has
# no effect on the current app.
# -----------------------------------------------------------------------------
# Host binding for a future Node server behind a reverse proxy (nginx).
# HOST=127.0.0.1
#
# Future app environment label (e.g. "staging" | "production").
# VITE_APP_ENV=staging
#
# Future database connection string (Postgres, etc.). NOT used today.
# DATABASE_URL=
#
# Future AI provider key. NOT used today — current "AI" features are simulated.
# OPENAI_API_KEY=
