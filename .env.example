# LandonOS / CCA Command Center — example environment file (INTERNAL ONLY)
# -----------------------------------------------------------------------------
# Copy to ".env" on the server or dev machine:
#     cp .env.example .env
# PLACEHOLDERS ONLY in git — set real values on the server; never commit .env.

# =============================================================================
# LIVE VPS (landon.cagteam.net) — required for PM2 landonos-api
# =============================================================================

# Postgres (Docker Compose postgres service on localhost:5432)
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/landonos

# API listen port — nginx proxies /api and /health here
# PORT=3001

# Required on VPS for secure httpOnly session cookies
# NODE_ENV=production

# UI environment label
# VITE_APP_ENV=production

# Optional — extra write protection when no session cookie (rebuild SPA if set)
# API_KEY=replace-with-long-random-string
# VITE_API_KEY=replace-with-long-random-string

# SPA API origin — leave empty for same-origin /api via nginx
# VITE_API_BASE_URL=

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================

# Vite dev server port (not used when nginx serves production build)
PORT=5000

# Base path (usually /)
# BASE_PATH=/

# Vite dev proxy target for /api
# API_PROXY_TARGET=http://127.0.0.1:3001

# Local DATABASE_URL example (matches docker-compose.yml dev defaults only):
# DATABASE_URL=postgres://landonos:landonos@127.0.0.1:5432/landonos

# =============================================================================
# DOCKER COMPOSE (Postgres on VPS)
# =============================================================================

# Override in .env if you change compose credentials (dev/staging only):
# POSTGRES_USER=landonos
# POSTGRES_PASSWORD=replace-with-strong-password
# POSTGRES_DB=landonos

# =============================================================================
# FUTURE — not wired yet
# =============================================================================

# VITE_OPENAI_API_KEY=
